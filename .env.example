# Copy to ".env" and fill in.

# Public host or IP where the hbbs/hbbr ports are reachable from your clients.
# On a remote server this is its public IP or DNS name (e.g. relay.example.com).
# hbbs hands this address to clients as the relay endpoint, so it MUST be the
# address clients can actually reach — not an internal/Docker IP.
RUSTDESK_SERVER_HOST=your.server.public.ip
