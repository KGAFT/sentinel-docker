# --- Secrets / local config -------------------------------------------------
# .env holds the live deployment values; never commit it. Use .env.example.
.env
.env.*
!.env.example

# --- RustDesk server runtime data -------------------------------------------
# Keys (id_ed25519 private key!) and the peer SQLite DB are generated at first
# boot and are host-specific. Never commit them.
server/data/

# --- IDE / editor -----------------------------------------------------------
.idea/
.vscode/
*.swp

# --- OS junk ----------------------------------------------------------------
.DS_Store
Thumbs.db
